<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>OTC AI • Terms of Service</title>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Inter,sans-serif;
}

body{

background:
radial-gradient(circle at top,#312e81 0%,transparent 35%),
#020617;

color:#fff;

}

.container{

max-width:1000px;

margin:auto;

padding:80px 25px;

}

.card{

background:rgba(255,255,255,.05);

backdrop-filter:blur(25px);

border:1px solid rgba(255,255,255,.08);

padding:45px;

border-radius:28px;

box-shadow:0 0 40px rgba(124,58,237,.15);

}

h1{

font-size:48px;

margin-bottom:15px;

background:linear-gradient(90deg,#ffffff,#8b5cf6);

-webkit-background-clip:text;

-webkit-text-fill-color:transparent;

}

h2{

margin-top:40px;

margin-bottom:15px;

color:#a78bfa;

}

p,li{

color:#cbd5e1;

line-height:1.9;

}

ul{

padding-left:20px;

}

.language{

float:right;

margin-top:-10px;

}

select{

background:#111827;

color:white;

padding:10px;

border-radius:12px;

border:1px solid rgba(255,255,255,.15);

}

footer{

margin-top:50px;

text-align:center;

color:#94a3b8;

}

</style>

<script>

function changeLang(){

const lang=document.getElementById("lang").value;

if(lang==="ru")
location.href="terms_ru.html";

if(lang==="en")
location.href="terms.html";

}

</script>

</head>

<body>

<div class="container">

<div class="card">

<div class="language">

<select id="lang" onchange="changeLang()">

<option value="en">🇺🇸 English</option>

<option value="ru">🇷🇺 Русский</option>

</select>

</div>

